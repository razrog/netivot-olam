# Copy to .env and fill in. Never commit .env.

# --- Server ---
PORT=3000
NODE_ENV=development
# Signs session cookies. Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- Database ---
# SQLite file path. Lives on local disk; back it up.
DB_PATH=data/netivot.db

# --- Storage backend: "local" | "gdrive" | "r2" | "s3" ---
STORAGE_PROVIDER=local

# How long streaming signed URLs stay valid (seconds). Used by r2/s3.
SIGNED_URL_TTL=600

# local provider: folder of .mp3 files
LOCAL_MEDIA_DIR=media

# gdrive provider (only needed when STORAGE_PROVIDER=gdrive)
GDRIVE_FOLDER_ID=
# Path to a Google service-account JSON key with read access to the folder
GOOGLE_APPLICATION_CREDENTIALS=

# s3 / r2 provider (only needed when STORAGE_PROVIDER=r2 or s3)
S3_BUCKET=
S3_REGION=auto
# R2 endpoint, e.g. https://<accountid>.r2.cloudflarestorage.com (leave blank for AWS S3)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set true only if your provider needs path-style addressing
S3_FORCE_PATH_STYLE=false

# --- Indexer ---
# How often to scan storage for new files (cron syntax)
INDEX_CRON=*/15 * * * *
# Read MP3 duration while indexing (set to false to speed up large scans)
READ_DURATION=true

# --- First admin (seeded on first boot only, if no users exist) ---
SEED_ADMIN_EMAIL=admin@example.com
# Leave blank to skip seeding; set a strong password to create the first admin
SEED_ADMIN_PASSWORD=
